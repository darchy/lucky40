    "build-produ777": "cross-env ENV=produ777 NAME=produ777 yarn run webpack --progress",
    "build-uat": "cross-env ENV=uat NAME=uat AFF_NAME=Ultimate777.com yarn run webpack --progress",
    "build-dule": "cross-env ENV=dule NAME=dule yarn run webpack --progress",
    "lint": "yarn run eslint --fix ./**/*.ts",
    "format": "yarn run prettier --write ./**/*.ts",
    "postinstall": "husky install"
  },
